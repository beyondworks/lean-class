# ──────────────────────────────────────────────────────────────
#  MCP API 키 발급처 — 발급 후 값을 mcp.template.json 의 <YOUR_...> 에 직접 넣으세요.
#  (Claude Code 는 .mcp.json 의 env 에 값을 직접 적습니다. 이 .env 파일 자체는
#   "어떤 키가 필요한지" 알려주는 목록일 뿐, 그대로 로드되지 않습니다.)
#  ⚠ 실제 키를 적은 파일은 절대 깃에 커밋하지 마세요. (.gitignore 에 .env 추가)
# ──────────────────────────────────────────────────────────────

# Hyperbrowser (클라우드 브라우저 자동화)   https://app.hyperbrowser.ai  → Settings → API Keys
HYPERBROWSER_API_KEY=

# 21st.dev Magic (UI 컴포넌트 생성)        https://21st.dev/magic  → Dashboard → API Key
TWENTYFIRST_API_KEY=

# TestSprite (자동 테스트 생성/실행)        https://www.testsprite.com  → Settings → API Key
TESTSPRITE_API_KEY=

# Notion (워크스페이스 연동)               https://www.notion.so/my-integrations  → New integration → Internal Integration Token
#   발급한 토큰을 mcp.template.json 의 OPENAPI_MCP_HEADERS Bearer 자리에 넣고,
#   연동할 Notion 페이지/DB 에 integration 을 Connect 해야 합니다.
NOTION_INTEGRATION_TOKEN=

# Linear 는 키 불필요 (브라우저 OAuth). context7 / sequential-thinking / playwright /
# shadcn-ui / ui-expert / design-systems / stitch 도 키 없이 동작합니다.

# ── 고급: 로컬 의존 MCP (선택) — 해당 서비스를 직접 띄워야 동작 ──
# n8n (워크플로 자동화 — 본인 n8n 인스턴스 필요)
N8N_API_URL=
N8N_API_KEY=
# Obsidian (Local REST API 플러그인 필요)
OBSIDIAN_API_KEY=
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124
